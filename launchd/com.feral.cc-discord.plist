    <string>/Users/feral/.npm-global/bin:/opt/homebrew/bin:/opt/homebrew/opt/node@22/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>npm_config_cache</key>
    <string>/Users/feral/.npm-cache-money-brain</string>
