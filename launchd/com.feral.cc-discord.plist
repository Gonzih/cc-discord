  <key>KeepAlive</key>
  <true/>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/feral/Library/Logs/cc-discord.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/feral/Library/Logs/cc-discord.error.log</string>

  <key>WorkingDirectory</key>
  <string>/Users/feral/money-brain</string>
