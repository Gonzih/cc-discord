  <string>com.feral.cc-discord</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/opt/node@22/bin/npx</string>
    <string>--prefer-online</string>
    <string>@gonzih/cc-discord@latest</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>DISCORD_BOT_TOKEN</key>
    <string>FILL_IN_TUESDAY</string>
    <key>DISCORD_GUILD_IDS</key>
    <string>FILL_IN_TUESDAY</string>
    <key>DISCORD_ALLOWED_USER_IDS</key>
    <string>FILL_IN_TUESDAY</string>
    <key>DISCORD_NOTIFY_CHANNEL_ID</key>
    <string>FILL_IN_TUESDAY</string>
    <key>CLAUDE_CODE_OAUTH_TOKEN</key>
    <string>FILL_IN_TUESDAY</string>
    <key>CC_DISCORD_NAMESPACE</key>
